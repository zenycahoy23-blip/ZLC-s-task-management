pipeline {
    agent any
    
    environment {
        DOCKER_REGISTRY = 'docker.io'
        DOCKER_USERNAME = credentials('docker-username')
        DOCKER_PASSWORD = credentials('docker-password')
        IMAGE_PHP = "docker.io/indae2/tms-php"
        IMAGE_FRONTEND = "docker.io/indae2/tms-frontend"
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '==== Checking out code ===='
                checkout scm
            }
        }
        
        stage('Build PHP Image') {
            steps {
                echo '==== Building PHP Docker image ===='
                sh 'cd laravel && docker build -t ${IMAGE_PHP}:${BUILD_NUMBER} . && docker tag ${IMAGE_PHP}:${BUILD_NUMBER} ${IMAGE_PHP}:latest'
            }
        }
        
        stage('Build Frontend Image') {
            steps {
                echo '==== Building Frontend Docker image ===='
                sh 'cd frontend && docker build -t ${IMAGE_FRONTEND}:${BUILD_NUMBER} . && docker tag ${IMAGE_FRONTEND}:${BUILD_NUMBER} ${IMAGE_FRONTEND}:latest'
            }
        }
        
        stage('Push to Docker Hub') {
            steps {
                echo '==== Pushing images to Docker Hub ===='
                sh '''
                    echo ${DOCKER_PASSWORD} | docker login -u ${DOCKER_USERNAME} --password-stdin
                    docker push ${IMAGE_PHP}:${BUILD_NUMBER}
                    docker push ${IMAGE_PHP}:latest
                    docker push ${IMAGE_FRONTEND}:${BUILD_NUMBER}
                    docker push ${IMAGE_FRONTEND}:latest
                    docker logout
                '''
            }
        }
        
        stage('Verify Deploy') {
            steps {
                echo "✅ Images ready for deployment"
                echo "PHP: ${IMAGE_PHP}:${BUILD_NUMBER}"
                echo "Frontend: ${IMAGE_FRONTEND}:${BUILD_NUMBER}"
            }
        }
    }
    
    post {
        success {
            echo '✅ Build completed successfully!'
        }
        failure {
            echo '❌ Build failed - check logs above'
        }
    }
}
